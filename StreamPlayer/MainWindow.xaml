<Window x:Class="StreamPlayer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vlc="clr-namespace:LibVLCSharp.WPF;assembly=LibVLCSharp.WPF"
        Title="Stream Player" Width="960" Height="700" MinWidth="640" MinHeight="480"
        Background="#121212">
    <Window.Resources>
        <Style x:Key="TransportButton" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Width" Value="38"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#333"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Foreground" Value="#555"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="PlayButton" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#CC0000"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="3"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E60000"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#555"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- Row 0: URL bar     -->
            <RowDefinition Height="*"/>      <!-- Row 1: Video       -->
            <RowDefinition Height="Auto"/>   <!-- Row 2: Info bar    -->
            <RowDefinition Height="Auto"/>   <!-- Row 3: Transport   -->
        </Grid.RowDefinitions>

        <!-- ═══ Row 0: URL bar ═══ -->
        <Border Grid.Row="0" Background="#1E1E1E" Padding="12,10">
            <StackPanel>
                <StackPanel Orientation="Horizontal">
                    <TextBox x:Name="UrlBox"
                             Text="{Binding Url, UpdateSourceTrigger=PropertyChanged}"
                             Width="560" Height="34"
                             VerticalContentAlignment="Center"
                             Padding="8,0" FontSize="13"
                             Background="#2D2D2D" Foreground="White"
                             CaretBrush="White" BorderBrush="#555" BorderThickness="1">
                        <TextBox.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="3"/>
                            </Style>
                        </TextBox.Resources>
                    </TextBox>
                    <Button Content="▶  Play" Command="{Binding PlayCommand}"
                            Margin="10,0,0,0" Style="{StaticResource PlayButton}"/>
                </StackPanel>
                <TextBlock Text="{Binding ValidationMessage}" Foreground="#FF6B6B"
                           FontSize="11" Margin="2,5,0,0">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ValidationMessage}" Value="">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
                <TextBlock Text="{Binding StatusMessage}" Foreground="#AAAAAA"
                           FontSize="11" Margin="2,5,0,0">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding StatusMessage}" Value="">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </StackPanel>
        </Border>

        <!-- ═══ Row 1: Video ═══ -->
        <vlc:VideoView x:Name="VideoPlayer" Grid.Row="1" Background="Black"/>

        <!-- ═══ Row 2: Info bar (hidden until metadata arrives) ═══ -->
        <Border Grid.Row="2" Background="#181818" Padding="10,8"
                Visibility="{Binding HasMetadata, Converter={StaticResource BoolToVis}}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>  <!-- thumbnail   -->
                    <ColumnDefinition Width="*"/>     <!-- title stack -->
                    <ColumnDefinition Width="Auto"/>  <!-- duration    -->
                </Grid.ColumnDefinitions>

                <!-- Thumbnail -->
                <Image x:Name="ThumbnailImage"
                       Grid.Column="0"
                       Width="120" Height="68"
                       Stretch="UniformToFill"
                       RenderOptions.BitmapScalingMode="HighQuality"
                       Margin="0,0,12,0"/>

                <!-- Title + Channel -->
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="{Binding VideoInfo.Title}"
                               Foreground="White" FontSize="14" FontWeight="SemiBold"
                               TextTrimming="CharacterEllipsis"/>
                    <TextBlock Foreground="#AAAAAA" FontSize="12" Margin="0,3,0,0"
                               TextTrimming="CharacterEllipsis">
                        <Run Text="{Binding VideoInfo.Channel, Mode=OneWay}"/>
                    </TextBlock>
                </StackPanel>

                <!-- Duration from metadata -->
                <TextBlock Grid.Column="2"
                           Text="{Binding VideoInfo.DurationMs, Converter={StaticResource MsToTimeConverter}}"
                           Foreground="#888" FontSize="12" FontFamily="Consolas"
                           VerticalAlignment="Center" Margin="12,0,0,0"/>
            </Grid>
        </Border>

        <!-- ═══ Row 3: Transport controls ═══ -->
        <Border Grid.Row="3" Background="#1A1A1A" Padding="10,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>  <!-- buttons       -->
                    <ColumnDefinition Width="*"/>     <!-- seek slider   -->
                    <ColumnDefinition Width="Auto"/>  <!-- chapter name  -->
                    <ColumnDefinition Width="Auto"/>  <!-- time display  -->
                </Grid.ColumnDefinitions>

                <!-- Transport buttons -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center"
                            Margin="0,0,8,0">
                    <Button Command="{Binding RewindCommand}"
                            Style="{StaticResource TransportButton}" ToolTip="-10 seconds">
                        <TextBlock Text="⏮" FontSize="18"/>
                    </Button>
                    <Button Command="{Binding PauseResumeCommand}"
                            Style="{StaticResource TransportButton}" Margin="2,0" ToolTip="Pause / Resume">
                        <Button.Content>
                            <TextBlock FontSize="18">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="▶"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsPlaying}" Value="True">
                                                <Setter Property="Text" Value="⏸"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Button.Content>
                    </Button>
                    <Button Command="{Binding StopCommand}"
                            Style="{StaticResource TransportButton}" Margin="2,0" ToolTip="Stop">
                        <TextBlock Text="⏹" FontSize="18"/>
                    </Button>
                    <Button Command="{Binding FastForwardCommand}"
                            Style="{StaticResource TransportButton}" ToolTip="+10 seconds">
                        <TextBlock Text="⏭" FontSize="18"/>
                    </Button>
                </StackPanel>

                <!-- Seek slider with chapter tick marks -->
                <Slider x:Name="SeekSlider"
                        Grid.Column="1"
                        Value="{Binding SliderPosition, Mode=TwoWay}"
                        Minimum="0" Maximum="1"
                        IsEnabled="{Binding CanControl}"
                        VerticalAlignment="Center"
                        Margin="4,0"/>

                <!-- Current chapter name -->
                <TextBlock Grid.Column="2"
                           Text="{Binding CurrentChapterTitle}"
                           Foreground="#777" FontSize="11"
                           VerticalAlignment="Center"
                           MaxWidth="220" TextTrimming="CharacterEllipsis"
                           Margin="6,0">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding CurrentChapterTitle}" Value="">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <!-- Time display -->
                <TextBlock Grid.Column="3"
                           Text="{Binding TimeDisplay}"
                           Foreground="#AAAAAA" FontSize="12"
                           VerticalAlignment="Center"
                           Margin="4,0,0,0"
                           FontFamily="Consolas"/>
            </Grid>
        </Border>
    </Grid>
</Window>
